    "release": "2026-06-17.0",
    "bucket": "s3://overturemaps-us-west-2/release",
    "region": "us-west-2",
    "release_note": "Pinned release verified 2026-07-02. To use latest, override GPQ_OVERTURE_RELEASE env var or query the STAC catalog at https://stac.overturemaps.org/catalog.json (SET VARIABLE latest = (SELECT latest FROM 'https://stac.overturemaps.org/catalog.json'))."
  },
  "profiles": {
    "default": "small + medium tiers, target < 2-3 GB total (fetch.sh)",
